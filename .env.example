# ===========================================
# Frontend Configuration (Angular + Nginx)
# ===========================================

# URL de la API para el navegador (cliente)
# Esta es la URL que la aplicación Angular usa para hacer peticiones HTTP
# Se inyecta en window.env.apiUrl en runtime
# Usar URL relativa para que funcione con cualquier dominio/puerto
API_URL=/api

# Modo producción (true/false)
# Controla el flag environment.production en Angular
PRODUCTION=true

# ===========================================
# Notas de Uso
# ===========================================

# Esta configuración es para el contenedor frontend que solo sirve archivos estáticos.
# El proxy reverso (routing de /api/* al backend) debe configurarse externamente:
#
# Opciones de arquitectura:
# - Docker Compose: Usar nginx/traefik como proxy reverso separado
# - Kubernetes: Usar Ingress controller con path-based routing
# - Cloud: Usar load balancer (AWS ALB, GCP LB, Azure App Gateway)
#
# Ejemplo con Docker Compose:
#   frontend:
#     image: sgv-frontend:latest
#     environment:
#       - API_URL=/api
#       - PRODUCTION=true
#
#   proxy:
#     image: nginx:alpine
#     # Configurar proxy de /api/* -> http://backend:3000
